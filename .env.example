# ── LLM Provider ──────────────────────────────────────────────
# Supported: openai, deepseek, zhipu, moonshot, qwen, azure,
#            anthropic, gemini, ollama, openrouter, siliconflow, groq
LANGCHAIN_PROVIDER=openai

# Model name (provider-specific)
LANGCHAIN_MODEL_NAME=gpt-4o-mini

# ── API Keys ──────────────────────────────────────────────────
# Only set the key for your chosen provider
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# DeepSeek
# LANGCHAIN_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# LANGCHAIN_MODEL_NAME=deepseek-chat

# Zhipu (智谱)
# LANGCHAIN_PROVIDER=zhipu
# ZHIPU_API_KEY=...

# Moonshot (月之暗面)
# LANGCHAIN_PROVIDER=moonshot
# MOONSHOT_API_KEY=sk-...
# LANGCHAIN_MODEL_NAME=moonshot-v1-8k

# Qwen (通义千问)
# LANGCHAIN_PROVIDER=qwen
# DASHSCOPE_API_KEY=sk-...

# Azure OpenAI
# LANGCHAIN_PROVIDER=azure
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
# OPENAI_API_VERSION=2024-06-01
# LANGCHAIN_MODEL_NAME=gpt-4o

# Anthropic
# LANGCHAIN_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# LANGCHAIN_PROVIDER=gemini
# GOOGLE_API_KEY=...

# Ollama (local)
# LANGCHAIN_PROVIDER=ollama
# LANGCHAIN_MODEL_NAME=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter
# LANGCHAIN_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...

# SiliconFlow
# LANGCHAIN_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=sk-...

# Groq
# LANGCHAIN_PROVIDER=groq
# GROQ_API_KEY=gsk_...
