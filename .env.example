# ── LLM Provider ──────────────────────────────────────────────
# Supported: openai, deepseek, zhipu, moonshot, qwen, azure,
#            anthropic, gemini, ollama, openrouter, siliconflow, groq
LANGCHAIN_PROVIDER=openai

# Model name (provider-specific)
LANGCHAIN_MODEL_NAME=gpt-4o-mini

# ── API Keys ──────────────────────────────────────────────────
# Only set the key for your chosen provider
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# DeepSeek
# LANGCHAIN_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# LANGCHAIN_MODEL_NAME=deepseek-chat

# Zhipu (智谱)
# LANGCHAIN_PROVIDER=zhipu
# ZHIPU_API_KEY=...

# Moonshot (月之暗面)
# LANGCHAIN_PROVIDER=moonshot
# MOONSHOT_API_KEY=sk-...
# LANGCHAIN_MODEL_NAME=moonshot-v1-8k

# MiniMax
# LANGCHAIN_PROVIDER=minimax
# MINIMAX_API_KEY=...
# LANGCHAIN_MODEL_NAME=MiniMax-M3

# Qwen (通义千问)
# LANGCHAIN_PROVIDER=qwen
# DASHSCOPE_API_KEY=sk-...

# Azure OpenAI
# LANGCHAIN_PROVIDER=azure
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
# OPENAI_API_VERSION=2024-06-01
# LANGCHAIN_MODEL_NAME=gpt-4o

# Anthropic
# LANGCHAIN_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# LANGCHAIN_PROVIDER=gemini
# GOOGLE_API_KEY=...

# Ollama (local)
# LANGCHAIN_PROVIDER=ollama
# LANGCHAIN_MODEL_NAME=llama3
# OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter
# LANGCHAIN_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...

# SiliconFlow
# LANGCHAIN_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=sk-...

# Groq
# LANGCHAIN_PROVIDER=groq
# GROQ_API_KEY=gsk_...

# ══════════════════════════════════════════════════════════════
# IM Gateway (企业微信 / 个人微信)
# ══════════════════════════════════════════════════════════════
# 只需在这里填凭据，然后运行 `python gateway.py init` 自动生成
# gateway.yaml —— 无需手动编辑 yaml。
# 规则：某平台的“必填项”全部填好后，该平台会被自动启用；
#       留空则该平台保持关闭。
# 改完 .env 后：python gateway.py init --force && python gateway.py doctor

# ── 企业微信 wecom（必填全 5 项才会启用）──────────────────────
# WECOM_CORP_ID=
# WECOM_AGENT_ID=
# WECOM_SECRET=
# WECOM_TOKEN=
# WECOM_AES_KEY=
# 允许触发的用户（逗号分隔；留空=允许所有人）
# WECOM_ALLOW_FROM=

# ── 个人微信 weixin / ilink ──────────────────────────────────
# 推荐：无需在此填账号，直接 `python gateway.py login weixin` 扫码即可，
#       扫码确认后服务端自动回传 account_id+bot_token 并启用该平台。
# 下面两项仅在你已有 bot 凭据、想跳过扫码时手动填写（填好会自动启用）：
# WEIXIN_ACCOUNT_ID=
# WEIXIN_TOKEN=
# 私聊策略：disabled | allowlist | open（默认 allowlist）
# WEIXIN_DM_POLICY=allowlist
# 私聊白名单（逗号分隔；allowlist 下留空=无人能触发）
# WEIXIN_ALLOW_FROM=
# 群聊策略：disabled | allowlist | open（默认 disabled）
# WEIXIN_GROUP_POLICY=disabled
# 群聊白名单（逗号分隔）
# WEIXIN_GROUP_ALLOW_FROM=

# ── 网关通用（均有默认值，按需覆盖）──────────────────────────
# GATEWAY_HOST=0.0.0.0
# GATEWAY_PORT=8645
# GATEWAY_DATA_DIR=~/.mini-agent/gateway
# GATEWAY_LOG_LEVEL=INFO
